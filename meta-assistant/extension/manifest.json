{
  "manifest_version": 3,
  "name": "KP Meta Assistant",
  "version": "0.1.0",
  "description": "Thai customer-service assistant for Meta Business Suite (KP Wallpanel). Translation + reply suggestions, human-in-the-loop. No API keys in this extension.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://business.facebook.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": { "service_worker": "background/sw.js" },
  "content_scripts": [
    {
      "matches": ["https://business.facebook.com/*"],
      "js": [
        "content/selectors.js",
        "content/inbox-live.js",
        "content/composer.js",
        "content/overlay.js",
        "content/inbox-observer.js"
      ],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "action": { "default_title": "KP Meta Assistant" }
}
